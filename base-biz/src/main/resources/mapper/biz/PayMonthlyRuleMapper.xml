<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.jiumai.base.biz.mapper.PayMonthlyRuleMapper">

    <!-- 通用查询结果列 -->
    <sql id="Base_Column_List">
        `id`,
        `pay_monthly_rule_code`,
        `pay_monthly_rule_name`,
        `parking_lot_code`,
        `charge_amount`,
        `create_id`,
        `create_name`,
        `create_date`,
        `create_phone`,
        `modify_id`,
        `modify_name`,
        `modify_date`,
        `del_flag`,
        `version`
    </sql>

    <select id="findPayMonthlyRulePage" resultType="com.jiumai.base.biz.vo.PayMonthlyRuleVO">
        SELECT <include refid="Base_Column_List"></include>
        FROM pm_pay_monthly_rule
        WHERE del_flag = 1
    </select>
</mapper>
