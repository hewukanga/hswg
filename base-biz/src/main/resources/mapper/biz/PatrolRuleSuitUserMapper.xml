<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.jiumai.base.biz.mapper.PatrolRuleSuitUserMapper">

    <!-- 通用查询结果列 -->
    <sql id="Base_Column_List">
        `id`,
        `rule_id`,
        `op_id`,
        `op_name`,
        `del_flag`,
        `version`
    </sql>

    <select id="findPatrolRuleSuitUserPage" resultType="com.jiumai.base.biz.vo.PatrolRuleSuitUserVO">
        SELECT <include refid="Base_Column_List"></include>
        FROM pm_patrol_rule_suit_user
        WHERE del_flag = 1
    </select>
</mapper>
