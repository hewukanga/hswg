<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.jiumai.base.biz.mapper.PatrolRulePointMapper">

    <!-- 通用查询结果列 -->
    <sql id="Base_Column_List">
        `id`,
        `rule_id`,
        `point_id`,
        `del_flag`,
        `version`
    </sql>

    <select id="findPatrolRulePointPage" resultType="com.jiumai.base.biz.vo.PatrolRulePointVO">
        SELECT <include refid="Base_Column_List"></include>
        FROM pm_patrol_rule_point
        WHERE del_flag = 1
    </select>
</mapper>
