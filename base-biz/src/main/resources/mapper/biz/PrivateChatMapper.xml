<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.jiumai.base.biz.mapper.PrivateChatMapper">

    <!-- 通用查询结果列 -->
    <sql id="Base_Column_List">
        `id`,
        `private_chat_relation_id`,
        `message_content`,
        `message_date`,
        `receiver_id`,
        `sender_id`,
        `private_message_type`
    </sql>

    <select id="findPrivateChatPage" resultType="com.jiumai.base.biz.vo.PrivateChatVO">
        SELECT <include refid="Base_Column_List"></include>
        FROM pm_private_chat
    </select>
</mapper>
