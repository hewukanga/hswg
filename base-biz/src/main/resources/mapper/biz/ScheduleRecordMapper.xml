<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.jiumai.base.biz.mapper.ScheduleRecordMapper">

    <!-- 通用查询结果列 -->
    <sql id="Base_Column_List">
        `id`,
        `op_id`,
        `schedule_date`,
        `start_time`,
        `end_time`,
        `del_flag`,
        `version`
    </sql>

    <select id="findScheduleRecordPage" resultType="com.jiumai.base.biz.vo.ScheduleRecordVO">
        SELECT <include refid="Base_Column_List"></include>
        FROM pm_schedule_record
        WHERE del_flag = 1
    </select>
</mapper>
