<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.jiumai.base.biz.mapper.IntegralGoodsExchangeMapper">

    <!-- 通用查询结果列 -->
    <sql id="Base_Column_List">
        `id`,
        `goods_id`,
        `goods_title`,
        `user_id`,
        `user_name`,
        `phone`,
        `address`,
        `sign_in_status`,
        `create_id`,
        `create_name`,
        `create_date`,
        `modify_id`,
        `modify_name`,
        `modify_date`,
        `del_flag`,
        `version`
    </sql>

    <select id="findIntegralGoodsExchangePage" resultType="com.jiumai.base.biz.vo.IntegralGoodsExchangeVO">
        SELECT <include refid="Base_Column_List"></include>
        FROM pm_integral_goods_exchange
        WHERE del_flag = 1
    </select>
</mapper>
