<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.jiumai.base.biz.mapper.PostAddressMapper">

    <!-- 通用查询结果列 -->
    <sql id="Base_Column_List">
        `id`,
        `post_id`,
        `address_name`,
        `address_longitude`,
        `address_latitude`,
        `choose_status`,
        `use_status`,
        `sort`,
        `create_id`,
        `create_name`,
        `create_date`,
        `modify_id`,
        `modify_name`,
        `modify_date`,
        `del_flag`,
        `version`,
        `address_name_prefix`
    </sql>

    <select id="findPostAddressPage" resultType="com.jiumai.base.biz.vo.PostAddressVO">
        SELECT <include refid="Base_Column_List"></include>
        FROM pm_post_address
        WHERE del_flag = 1
    </select>
</mapper>
