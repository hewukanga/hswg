<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.jiumai.base.biz.mapper.IntegralGoodsMapper">

    <!-- 通用查询结果列 -->
    <sql id="Base_Column_List">
        `id`,
        `goods_title`,
        `goods_type`,
        `goods_cover_image`,
        `goods_description`,
        `goods_need_integral`,
        `goods_stock`,
        `goods_end_date`,
        `goods_area_path`,
        `goods_top_status`,
        `create_id`,
        `create_name`,
        `create_date`,
        `modify_id`,
        `modify_name`,
        `modify_date`,
        `del_flag`,
        `version`,
        `goods_total`
    </sql>

    <select id="findIntegralGoodsPage" resultType="com.jiumai.base.biz.vo.IntegralGoodsVO">
        SELECT <include refid="Base_Column_List"></include>
        FROM pm_integral_goods
        WHERE del_flag = 1
    </select>
</mapper>
