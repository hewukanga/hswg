<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.jiumai.base.biz.mapper.AttendanceRuleDateMapper">

    <!-- 通用查询结果列 -->
    <sql id="Base_Column_List">
        `id`,
        `rule_id`,
        `week`,
        `start_time`,
        `end_time`,
        `del_flag`,
        `version`
    </sql>

    <select id="findAttendanceRuleDatePage" resultType="com.jiumai.base.biz.vo.AttendanceRuleDateVO">
        SELECT <include refid="Base_Column_List"></include>
        FROM pm_attendance_rule_date
        WHERE del_flag = 1
    </select>
</mapper>
