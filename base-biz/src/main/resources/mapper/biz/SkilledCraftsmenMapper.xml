<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.jiumai.base.biz.mapper.SkilledCraftsmenMapper">

    <!-- 通用查询结果列 -->
    <sql id="Base_Column_List">
        `id`,
        `street_id`,
        `street_name`,
        `street_path`,
        `community_id`,
        `community_name`,
        `community_path`,
        `user_name`,
        `age`,
        `phone`,
        `address`,
        `sex`,
        `party_member_status`,
        `talent_type`,
        `deed_description`,
        `images`,
        `create_id`,
        `create_name`,
        `create_date`,
        `modify_id`,
        `modify_name`,
        `modify_date`,
        `del_flag`,
        `version`
    </sql>

    <select id="findSkilledCraftsmenPage" resultType="com.jiumai.base.biz.vo.SkilledCraftsmenVO">
        SELECT <include refid="Base_Column_List"></include>
        FROM pm_skilled_craftsmen
        WHERE del_flag = 1
    </select>
</mapper>
