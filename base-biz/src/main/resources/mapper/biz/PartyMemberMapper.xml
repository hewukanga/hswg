<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.jiumai.base.biz.mapper.PartyMemberMapper">

    <!-- 通用查询结果列 -->
    <sql id="Base_Column_List">
        `id`,
        `street_id`,
        `street_name`,
        `street_path`,
        `community_id`,
        `community_name`,
        `community_path`,
        `user_name`,
        `age`,
        `join_organization_date`,
        `become_formal_party_member_date`,
        `phone`,
        `nation`,
        `native_place`,
        `party_seniority`,
        `sex`,
        `position`,
        `create_id`,
        `create_name`,
        `create_date`,
        `modify_id`,
        `modify_name`,
        `modify_date`,
        `del_flag`,
        `version`
    </sql>

    <select id="findPartyMemberPage" resultType="com.jiumai.base.biz.vo.PartyMemberVO">
        SELECT <include refid="Base_Column_List"></include>
        FROM pm_party_member
        WHERE del_flag = 1
    </select>
</mapper>
