<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.jiumai.base.biz.mapper.DocumentManagementMapper">

    <!-- 通用查询结果列 -->
    <sql id="Base_Column_List">
        `id`,
        `doc_name`,
        `doc_path`,
        `create_id`,
        `create_name`,
        `create_date`,
        `modify_id`,
        `modify_name`,
        `modify_date`,
        `del_flag`,
        `version`
    </sql>

    <select id="findDocumentManagementPage" resultType="com.jiumai.base.biz.vo.DocumentManagementVO">
        SELECT <include refid="Base_Column_List"></include>
        FROM pm_document_management
        WHERE del_flag = 1
    </select>
</mapper>
