<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.jiumai.base.biz.mapper.PayMonthlyUserInfoMapper">

    <!-- 通用查询结果列 -->
    <sql id="Base_Column_List">
        `id`,
        `contract_id`,
        `license_plate_number`,
        `parking_lot_code`,
        `parking_lot_name`,
        `parking_lot_address`,
        `service_telephone`,
        `pay_monthly_rule_code`,
        `charge_amount`,
        `monthly_card_validity_start_date`,
        `monthly_card_validity_end_date`,
        `monthly_pay_date`,
        `monthly_pay_amount`,
        `create_id`,
        `create_name`,
        `create_date`,
        `create_phone`,
        `modify_id`,
        `modify_name`,
        `modify_date`,
        `del_flag`,
        `version`
    </sql>

    <select id="findPayMonthlyUserInfoPage" resultType="com.jiumai.base.biz.vo.PayMonthlyUserInfoVO">
        SELECT <include refid="Base_Column_List"></include>
        FROM pm_pay_monthly_user_info
        WHERE del_flag = 1
    </select>
</mapper>
