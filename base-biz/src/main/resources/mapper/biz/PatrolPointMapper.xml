<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.jiumai.base.biz.mapper.PatrolPointMapper">

    <!-- 通用查询结果列 -->
    <sql id="Base_Column_List">
        `id`,
        `point_name`,
        `point_description`,
        `point_type`,
        `point_address`,
        `point_longitude`,
        `point_latitude`,
        `point_status`,
        `point_area_id`,
        `point_area_path`,
        `point_area_name`,
        `point_qr_code`,
        `create_id`,
        `create_name`,
        `create_date`,
        `modify_id`,
        `modify_name`,
        `modify_date`,
        `del_flag`,
        `version`
    </sql>

    <select id="findPatrolPointPage" resultType="com.jiumai.base.biz.vo.PatrolPointVO">
        SELECT <include refid="Base_Column_List"></include>
        FROM pm_patrol_point
        WHERE del_flag = 1
    </select>
</mapper>
